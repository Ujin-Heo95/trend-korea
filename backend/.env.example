# 로컬: postgresql://postgres:password@localhost:5432/trend_korea
# Supabase: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/trend_korea
YOUTUBE_API_KEY=your_youtube_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
KOPIS_API_KEY=your_kopis_api_key_here
KOBIS_API_KEY=your_kobis_api_key_here
KMA_API_KEY=your_kma_api_key_here
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
# data.go.kr 통합키 (관광공사 KorService2/searchFestival2, 관광 빅데이터 metcoRegnVisitrDDList, 문화체육관광부 publicperformancedisplays/period)
# 발급: https://www.data.go.kr/ → 마이페이지 → 인증키 발급 (신청 후 1~2일)
DATA_GO_KR_API_KEY=
# KCISA(한국문화정보원) OpenAPI — API 별로 별도 활용신청 필요. https://www.kcisa.kr/cop/bbs/BBSMSTR_000000000228/selectBoardList.do
KCISA_TRAVEL_API_KEY=
KCISA_FESTIVAL_API_KEY=
KCISA_EVENT_API_KEY=
KCISA_PERFORMANCE_API_KEY=
KCISA_EXHIBITION_API_KEY=
# 서울 열린데이터 광장 통합 인증키. 발급: https://data.seoul.go.kr/together/guide/useGuide.do
SEOUL_OPEN_API_KEY=
# Discord 웹훅 (선택). 스크래퍼 에러 알림용
DISCORD_WEBHOOK_URL=
PORT=4000
CRAWL_INTERVAL_MINUTES=10
# 포스트 보관 기간 (일). Supabase 무료 500MB. 기본값: 7
POST_TTL_DAYS=7
NODE_ENV=development
